{
  "name": "battlefield-shooter",
  "version": "1.0.0",
  "description": "3D战术射击游戏 - 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist-win": "electron-builder --win"
  },
  "author": "游戏开发者",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.shooter.battlefield",
    "productName": "战地射击",
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}],
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "../index.html",
      "../weather.html"
    ],
    "extraResources": [
      {"from": "../", "to": "game", "filter": ["index.html", "weather.html"]}
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052"
    }
  }
}
